# Copy this file to .env.local and fill in real values.
# Everything here is optional — features degrade gracefully when missing.

# --- Shared league state (Supabase) ---
# Without these, keeper selections live in localStorage on each device.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- AI features (Anthropic) ---
# Without this, the Advisor / Trade Evaluator / Rules Chat / Draft Recap
# routes return 503 with a setup hint. Server-side only — NEVER expose this
# to the browser (do not prefix with NEXT_PUBLIC_).
ANTHROPIC_API_KEY=dummy-key-for-dev